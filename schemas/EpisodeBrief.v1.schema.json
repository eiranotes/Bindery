{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bindery.episode_brief.v1",
  "type": "object",
  "required": ["schema_version", "episode", "goal", "must_events"],
  "properties": {
    "schema_version": { "const": "bindery.episode_brief.v1" },
    "episode": { "type": "string", "pattern": "^ep\\d{3}$" },
    "goal": { "type": "string" },
    "must_events": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "characters": { "type": "array", "items": { "type": "string" } },
    "locations": { "type": "array", "items": { "type": "string" } },
    "pov": { "type": "string" },
    "knowledge_change": { "type": "array", "items": { "type": "string" } },
    "emotion_change": { "type": "array", "items": { "type": "string" } },
    "conflict_change": { "type": "string" },
    "threads_touch": { "type": "array", "items": { "type": "string" } },
    "forbidden": { "type": "array", "items": { "type": "string" } },
    "target_length": { "type": "number", "exclusiveMinimum": 0 },
    "exit_hook": { "type": "string" }
  }
}
