{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bindery",
  "version": "0.3.0",
  "identifier": "app.bindery.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Bindery",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "Bindery Local",
    "category": "Productivity",
    "shortDescription": "Markdown-native fiction IDE",
    "longDescription": "A local-first writing IDE for serialized fiction projects.",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "perMachine",
        "languages": [
          "English",
          "Korean"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
